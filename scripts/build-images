#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CONFIG="${CONFIG:-$ROOT_DIR/config/love-android-versions.tsv}"
IMAGE_REPO="${IMAGE_REPO:-luke100000/love-android-builder}"
TAGS="${TAGS:-}"
PUSH="${PUSH:-0}"
PLATFORMS="${PLATFORMS:-}"
LATEST_TAG="${LATEST_TAG:-}"

ANDROID_COMPILE_SDK="${ANDROID_COMPILE_SDK:-34}"
ANDROID_BUILD_TOOLS="${ANDROID_BUILD_TOOLS:-34.0.0}"
ANDROID_NDK_VERSION="${ANDROID_NDK_VERSION:-26.1.10909125}"
ANDROID_CMAKE="${ANDROID_CMAKE:-3.22.1}"

fail() {
    echo "error: $*" >&2
    exit 1
}

usage() {
    cat <<'EOF'
Usage: scripts/build-images [--push] [--tag TAG ...]

Build Docker images for every row in config/love-android-versions.tsv, or for
selected image tags.

Environment:
  IMAGE_REPO              Docker repository, default: luke100000/love-android-builder
  CONFIG                  TSV config path, default: config/love-android-versions.tsv
  TAGS                    Space-separated image tags to build
  PUSH=1                  Push images with docker buildx
  PLATFORMS=linux/amd64   Optional buildx platforms, requires --push
  LATEST_TAG=11.5         Also tag this config row as IMAGE_REPO:latest
  ANDROID_NDK_VERSION     Android NDK version, default: 26.1.10909125

Examples:
  scripts/build-images
  scripts/build-images --tag 11.5
  scripts/build-images --push
EOF
}

while [ "$#" -gt 0 ]; do
    case "$1" in
        --push)
            PUSH=1
            ;;
        --tag)
            [ "$#" -ge 2 ] || fail "--tag requires a value"
            TAGS="${TAGS:+$TAGS }$2"
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            fail "unknown argument: $1"
            ;;
    esac
    shift
done

[ -f "$CONFIG" ] || fail "config file does not exist: $CONFIG"
[ "$PUSH" = "1" ] || [ -z "$PLATFORMS" ] || fail "PLATFORMS requires --push"

tag_selected() {
    local tag="$1"
    [ -z "$TAGS" ] && return 0
    local selected
    for selected in $TAGS; do
        [ "$selected" = "$tag" ] && return 0
    done
    return 1
}

build_one() {
    local image_tag="$1"
    local love_android_ref="$2"
    local image="$IMAGE_REPO:$image_tag"
    local args=(
        build
        --build-arg "LOVE_ANDROID_REF=$love_android_ref"
        --build-arg "ANDROID_COMPILE_SDK=$ANDROID_COMPILE_SDK"
        --build-arg "ANDROID_BUILD_TOOLS=$ANDROID_BUILD_TOOLS"
        --build-arg "ANDROID_NDK_VERSION=$ANDROID_NDK_VERSION"
        --build-arg "ANDROID_CMAKE=$ANDROID_CMAKE"
        -t "$image"
    )

    if [ "$LATEST_TAG" = "$image_tag" ]; then
        args+=(-t "$IMAGE_REPO:latest")
    fi

    if [ "$PUSH" = "1" ]; then
        args=(buildx "${args[@]}")
        [ -n "$PLATFORMS" ] && args+=(--platform "$PLATFORMS")
        args+=(--push)
    fi

    args+=("$ROOT_DIR")

    echo "Building $image from love-android ref $love_android_ref"
    docker "${args[@]}"
}

built=0
while IFS=$'\t' read -r image_tag love_android_ref _; do
    case "$image_tag" in
        ""|\#*) continue ;;
    esac
    [ -n "$love_android_ref" ] || fail "missing love_android_ref for tag $image_tag"
    if tag_selected "$image_tag"; then
        build_one "$image_tag" "$love_android_ref"
        built=$((built + 1))
    fi
done < "$CONFIG"

[ "$built" -gt 0 ] || fail "no matching tags selected"
